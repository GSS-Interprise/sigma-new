    {
      "parameters": {
        "jsCode": "// Consolida as msgs da fila em uma única chamada pra IA.\n// - Filtra placeholders [audio]/[imagem] do texto (a transcrição/análise vai ser feita na edge function)\n// - Identifica última mídia do batch (não só último item) — assim áudio + texto ainda transcreve o áudio\nlet items = $input.all();\n\n// PostgREST pode retornar array unwrapped (1 item por linha) ou wrapped (1 item com array).\nif (items.length === 1 && Array.isArray(items[0].json)) {\n  items = items[0].json.map(j => ({ json: j }));\n}\n\nif (items.length === 0) return [];\n\nconst msgs = items\n  .map(i => (i.json.msg_text || '').trim())\n  .filter(t => t.length > 0 && t !== '[audio]' && t !== '[imagem]' && t !== '[mensagem]');\nconst consolidated = msgs.join('\\n');\n\n// Última mídia do batch (procura de trás pra frente). Fallback: último item.\nlet mediaItem = null;\nfor (let i = items.length - 1; i >= 0; i--) {\n  const t = items[i].json.msg_type;\n  if (t === 'audio' || t === 'image') { mediaItem = items[i].json; break; }\n}\nconst ref = mediaItem || items[items.length - 1].json;\n\nconst ctx = $('Sou o dono?').first().json;\n\nreturn [{ json: {\n  phone: ctx.phone,\n  message_text: consolidated,\n  msg_type: ref.msg_type || 'text',\n  media_url: ref.media_url || '',\n  msg_id: ref.msg_id || '',\n  instance_name: ref.instance_name || '',\n  my_created_at: ctx.my_created_at,\n  msg_count: items.length\n} }];"
      },
