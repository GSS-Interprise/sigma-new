      "id": "webhook-in",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "campanha-webhook-bridge"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst event = body.event;\n\nif (event !== 'messages.upsert') return [];\n\nconst data = body.data || {};\nconst key = data.key || {};\n\nif (key.fromMe) return [];\nif ((key.remoteJid || '').includes('@g.us')) return [];\n\nconst msg = data.message || {};\nlet text = msg.conversation || (msg.extendedTextMessage || {}).text || '';\nlet msgType = 'text';\nlet mediaUrl = '';\n\nif (msg.audioMessage) {\n  msgType = 'audio';\n  mediaUrl = msg.audioMessage.url || '';\n  if (!text) text = '[audio]';\n} else if (msg.imageMessage) {\n  msgType = 'image';\n  mediaUrl = msg.imageMessage.url || '';\n  text = msg.imageMessage.caption || '[imagem]';\n} else if (!text) {\n  text = '[mensagem]';\n}\n\nconst phone = (key.remoteJid || '').replace('@s.whatsapp.net', '').replace('@lid', '');\nconst msgId = key.id || '';\n\n// Detecta quote (resposta citando msg anterior) — pode ser resposta de alerta Q&A\nconst ctxInfo = (msg.extendedTextMessage || {}).contextInfo || msg.contextInfo || {};\nconst quotedMsgId = ctxInfo.stanzaId || ctxInfo.quotedMessageId || '';\n\n// Detecta opt-out LGPD\nconst optOutRegex = /\\b(parar|pare|para de mandar|remov(a|er|e)|me (tira|retira)|n[\\u00e3a]o quero mais|n[\\u00e3a]o me mande|cancelar|descadastrar|sair da lista|stop|unsubscribe|chega|deixa pra l[\\u00e1a]|n[\\u00e3a]o perturbe|denunciar|procon|reclamar)\\b/i;\nconst isOptOut = optOutRegex.test(text);\n\nreturn [{ json: {\n  phone,\n  msg_id: msgId,\n  msg_text: text,\n  msg_type: msgType,\n  media_url: mediaUrl,\n  instance_name: body.instance || '',\n  is_opt_out: isOptOut,\n  quoted_msg_id: quotedMsgId,\n  is_quote_reply: !!quotedMsgId\n} }];"
      },
      "id": "parse",
      "name": "Parsear",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 0]
