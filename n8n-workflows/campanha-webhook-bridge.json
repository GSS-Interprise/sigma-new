    {
      "parameters": {
        "jsCode": "// Esta execução é a 'dona' da fila se a última linha desse phone for a minha.\n// Se outra msg entrou depois, eu descarto e deixo a execução mais nova processar.\nconst lastId = $json.id;\nconst myRow = $('Insert na fila').first().json;\nconst myId = myRow.id;\n\nif (lastId !== myId) {\n  // Não sou o dono — descarto silenciosamente\n  return [];\n}\n\nreturn [{ json: {\n  phone: myRow.phone,\n  my_created_at: myRow.created_at\n} }];"
      },
      "id": "am-i-owner",
